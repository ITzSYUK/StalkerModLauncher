<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>StalkerModLauncher</AssemblyName>
    <RootNamespace>StalkerModLauncher</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>..\..\icon.ico</ApplicationIcon>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Version>1.0.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="..\..\icons\arrow_variant_two\left-arrow.png" Link="Resources\left-arrow.png" />
    <Resource Include="..\..\icons\arrow_variant_two\right-arrow.png" Link="Resources\right-arrow.png" />
    <Resource Include="..\..\icons\add_mods.png" Link="Resources\add_mods.png" />
    <Resource Include="..\..\icons\scan_add_mods.png" Link="Resources\scan_add_mods.png" />
    <EmbeddedResource Include="Resources\ModLauncherLogo.png" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="DiscordRichPresence" Version="1.6.1.70" />
  </ItemGroup>
</Project>
