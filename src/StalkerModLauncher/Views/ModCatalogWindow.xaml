<Window x:Class="StalkerModLauncher.Views.ModCatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Браузер модификаций"
        Width="1060"
        Height="720"
        MinWidth="800"
        MinHeight="540"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_OnSourceInitialized">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="ShadowOfChernobylButton"
                        Content="Тень Чернобыля"
                        Click="ShadowOfChernobylButton_OnClick"
                        Margin="0,0,8,0"/>
                <Button x:Name="ClearSkyButton"
                        Content="Чистое Небо"
                        Click="ClearSkyButton_OnClick"
                        Margin="0,0,8,0"/>
                <Button x:Name="CallOfPripyatButton"
                        Content="Зов Припяти"
                        Click="CallOfPripyatButton_OnClick"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Grid Width="320"
                      Height="38"
                      Margin="0,0,8,0"
                      Background="Transparent"
                      PreviewMouseLeftButtonDown="SearchBoxChrome_OnPreviewMouseLeftButtonDown">
                    <Border Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <Grid Margin="8,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Width="18"
                                     Height="18"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     IsHitTestVisible="False">
                                <Canvas Width="18"
                                        Height="18"
                                        SnapsToDevicePixels="True">
                                    <Ellipse Width="10.5"
                                             Height="10.5"
                                             Canvas.Left="2.5"
                                             Canvas.Top="2.5"
                                             Stroke="{StaticResource AccentBrush}"
                                             StrokeThickness="1.7"/>
                                    <Path Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M11.2,11.2 L15.3,15.3"/>
                                </Canvas>
                            </Viewbox>
                            <Grid Grid.Column="1"
                                  Margin="7,0,0,0"
                                  VerticalAlignment="Center">
                                <TextBox x:Name="SearchTextBox"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         Height="20"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchTextBox_OnTextChanged">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="TextBox">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                                <TextBlock Text="Поиск по названию"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="1,2,0,0"
                                           Height="20"
                                           TextWrapping="NoWrap"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
                <Button Style="{StaticResource ModToolbarIconButtonStyle}"
                        Click="RefreshButton_OnClick"
                        ToolTip="Обновить список модификаций">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
