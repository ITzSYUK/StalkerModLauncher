<Window x:Class="StalkerModLauncher.Views.ProfileHealthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Состояние профиля"
        Width="900"
        Height="650"
        MinWidth="720"
        MinHeight="480"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_OnSourceInitialized">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Состояние профиля"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <TextBlock Text="{Binding ProfileName}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="15"/>
                <TextBlock Text="  ·  "
                           Foreground="{StaticResource DisabledTextBrush}"
                           FontSize="15"/>
                <TextBlock Text="{Binding ProfileKind}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="15"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource CommandPanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,14,0,12">
            <TextBlock Text="{Binding Summary}"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10,8"
                Margin="0,0,0,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanManageWorkspace}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*"/>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Workspace"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Workspace.StateDisplay, Mode=OneWay}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Workspace.StateDisplay, Mode=OneWay}"
                               Margin="0,1,0,0"/>
                </StackPanel>

                <UniformGrid Grid.Column="1"
                             Columns="3"
                             VerticalAlignment="Center"
                             Margin="18,0">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Видимый размер"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   ToolTip="Сколько данных видит игра внутри рабочей папки. Из-за ссылок это не равно расходу места на диске."/>
                        <TextBlock Text="{Binding Workspace.LogicalSizeDisplay, Mode=OneWay}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Реально занято"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"
                                   ToolTip="Сколько места примерно занимает workspace с учетом hardlink и symlink."/>
                        <TextBlock Text="{Binding Workspace.PhysicalSizeDisplay, Mode=OneWay}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                    <StackPanel ToolTip="{Binding Workspace.LinkSummaryDisplay, Mode=OneWay}">
                        <TextBlock Text="Файлы"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="11"/>
                        <TextBlock Text="{Binding Workspace.FileCountDisplay, Mode=OneWay}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Пересобрать"
                            Command="{Binding RebuildWorkspaceCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Перенести..."
                            Command="{Binding MoveWorkspaceCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Очистить кэш"
                            Command="{Binding ClearWorkspaceCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource FieldBackgroundBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Готовность"
                               FontSize="15"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PreflightExplanation}"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Checks}"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="8"
                                        Height="8"
                                        CornerRadius="4"
                                        VerticalAlignment="Top"
                                        Margin="0,7,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Margin="8,0,12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Details}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="4"
                   HorizontalAlignment="Right"
                   Margin="0,14,0,0">
            <Button Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Профиль"
                    Command="{Binding OpenProfileCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Сохранения"
                    Command="{Binding OpenSavesCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Последний лог"
                    Command="{Binding OpenLatestLogCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Crash dump"
                    Command="{Binding OpenCrashDumpCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Копировать отчет"
                    Command="{Binding CopyReportCommand}"/>
        </WrapPanel>
    </Grid>
</Window>
