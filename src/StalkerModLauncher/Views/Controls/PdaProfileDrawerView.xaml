<UserControl x:Class="StalkerModLauncher.Views.Controls.PdaProfileDrawerView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StalkerModLauncher;component/Themes/PdaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <BitmapImage x:Key="PdaDialogAtlasSource"
                     UriSource="/StalkerModLauncher;component/Resources/PdaDialogAtlas.png"/>
        <CroppedBitmap x:Key="PdaDialogTopLeft" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="0,0,32,32"/>
        <CroppedBitmap x:Key="PdaDialogTop" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="32,0,32,32"/>
        <CroppedBitmap x:Key="PdaDialogTopRight" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="64,0,32,32"/>
        <CroppedBitmap x:Key="PdaDialogLeft" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="0,32,32,32"/>
        <CroppedBitmap x:Key="PdaDialogCenter" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="32,32,32,32"/>
        <CroppedBitmap x:Key="PdaDialogRight" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="64,32,32,32"/>
        <CroppedBitmap x:Key="PdaDialogBottomLeft" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="0,64,32,32"/>
        <CroppedBitmap x:Key="PdaDialogBottom" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="32,64,32,32"/>
        <CroppedBitmap x:Key="PdaDialogBottomRight" Source="{StaticResource PdaDialogAtlasSource}" SourceRect="64,64,32,32"/>
        <Style x:Key="PdaDrawerActionStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Foreground" Value="#E4DFC9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="IconChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconChrome" Property="Background" Value="#B024303D"/>
                                <Setter TargetName="IconChrome" Property="BorderBrush" Value="#9AA6AE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IconChrome" Property="Background" Value="#73101823"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaInlineActionStyle" TargetType="Button" BasedOn="{StaticResource PdaDrawerActionStyle}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
        </Style>
        <Style x:Key="PdaProfileItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Foreground" Value="#8F948F"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#DA0A1018"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#556574"/>
                                <Setter Property="Foreground" Value="#DBDAD2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#D0223142"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#42576A"/>
                                <Setter Property="Foreground" Value="#F0EEE4"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemChrome" Property="Background" Value="#F00B111A"/>
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#687B8C"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="Transparent"
            BorderThickness="0"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.RowSpan="2" IsHitTestVisible="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>
                <Image Grid.Row="0" Grid.Column="0" Source="{StaticResource PdaDialogTopLeft}" Stretch="Fill"/>
                <Image Grid.Row="0" Grid.Column="1" Source="{StaticResource PdaDialogTop}" Stretch="Fill"/>
                <Image Grid.Row="0" Grid.Column="2" Source="{StaticResource PdaDialogTopRight}" Stretch="Fill"/>
                <Image Grid.Row="1" Grid.Column="0" Source="{StaticResource PdaDialogLeft}" Stretch="Fill"/>
                <Image Grid.Row="1" Grid.Column="1" Source="{StaticResource PdaDialogCenter}" Stretch="Fill"/>
                <Image Grid.Row="1" Grid.Column="2" Source="{StaticResource PdaDialogRight}" Stretch="Fill"/>
                <Image Grid.Row="2" Grid.Column="0" Source="{StaticResource PdaDialogBottomLeft}" Stretch="Fill"/>
                <Image Grid.Row="2" Grid.Column="1" Source="{StaticResource PdaDialogBottom}" Stretch="Fill"/>
                <Image Grid.Row="2" Grid.Column="2" Source="{StaticResource PdaDialogBottomRight}" Stretch="Fill"/>
            </Grid>

            <Grid Background="Transparent" Margin="8,7,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="ПРОФИЛИ"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="17"
                               Foreground="#949892"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,9,0" VerticalAlignment="Center">
                    <Button Command="{Binding NewProfileCommand}"
                            Style="{StaticResource PdaDrawerActionStyle}"
                            ToolTip="Создать профиль">
                        <Viewbox Width="22" Height="22">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="M11,13 V16 C11,16.283 11.096,16.521 11.288,16.713 C11.48,16.905 11.717,17.001 12,17 C12.283,16.999 12.52,16.903 12.713,16.712 C12.906,16.521 13.001,16.283 13,16 V13 H16 C16.283,13 16.521,12.904 16.713,12.712 C16.905,12.52 17.001,12.283 17,12 C16.999,11.717 16.903,11.48 16.712,11.288 C16.521,11.096 16.283,11 16,11 H13 V8 C13,7.717 12.904,7.479 12.712,7.288 C12.52,7.097 12.283,7.001 12,7 C11.717,6.999 11.48,7.095 11.288,7.288 C11.096,7.481 11,7.718 11,8 V11 H8 C7.717,11 7.479,11.096 7.288,11.288 C7.097,11.48 7.001,11.717 7,12 C6.999,12.283 7.095,12.52 7.288,12.713 C7.481,12.906 7.718,13.001 8,13 Z M5,21 C4.45,21 3.979,20.804 3.588,20.413 C3.197,20.022 3.001,19.551 3,19 V5 C3,4.45 3.196,3.979 3.588,3.588 C3.98,3.197 4.451,3.001 5,3 H19 C19.55,3 20.021,3.196 20.413,3.588 C20.805,3.98 21.001,4.451 21,5 V19 C21,19.55 20.804,20.021 20.413,20.413 C20.022,20.805 19.551,21.001 19,21 Z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Command="{Binding ImportProfileCommand}"
                            Style="{StaticResource PdaDrawerActionStyle}"
                            ToolTip="Импортировать профиль">
                        <Viewbox Width="22" Height="22">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="4" Canvas.Top="3" Width="16" Height="18" RadiusX="3" RadiusY="3"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.7"/>
                                <Path Data="M12,6 V15 M8.5,11.5 L12,15 L15.5,11.5 M8,18 H16"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

            <ListBox x:Name="ProfilesList"
                     Grid.Row="1"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     ItemContainerStyle="{StaticResource PdaProfileItemStyle}"
                     Margin="8,0,8,18"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ClipToBounds="True"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="ProfilesList_OnPreviewMouseLeftButtonDown"
                     PreviewMouseLeftButtonUp="ProfilesList_OnPreviewMouseLeftButtonUp"
                     MouseMove="ProfilesList_OnMouseMove"
                     DragOver="ProfilesList_OnDragOver"
                     DragLeave="ProfilesList_OnDragLeave"
                     Drop="ProfilesList_OnDrop"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="ProfileRow" MinHeight="46" VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch" Background="Transparent" ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="17" Height="17">
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStandalone}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                    <Path Data="M7.5,2 L13,5.2 L7.5,8.4 L2,5.2 Z" Fill="#282D1F" Stroke="#C8952D" StrokeThickness="1.1" StrokeLineJoin="Round"/>
                                    <Path Data="M2.5,7.7 L7.5,10.7 L12.5,7.7 M2.5,10.3 L7.5,13.3 L12.5,10.3"
                                          Stroke="#C8952D" StrokeThickness="1.1" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Canvas>
                                <Canvas Width="17" Height="17">
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsStandalone}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                    <Path Data="M3,5 L7.5,2.7 L12,5 L7.5,7.3 Z" Fill="#2E301F" Stroke="#C8952D" StrokeThickness="1.1" StrokeLineJoin="Round"/>
                                    <Path Data="M3,5 V10.6 L7.5,13.3 L12,10.6 V5 M7.5,7.3 V13.3"
                                          Stroke="#C8952D" StrokeThickness="1.1" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                </Canvas>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontFamily="Bahnschrift SemiCondensed"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="40"/>
                                <TextBlock Text="ЗАПУЩЕН"
                                           Margin="0,1,0,0"
                                           Foreground="#D39A2D"
                                           FontSize="10"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Border x:Name="ActionShade" Grid.ColumnSpan="3" Opacity="0" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#00000000" Offset="0"/>
                                        <GradientStop Color="#24070B11" Offset="0.38"/>
                                        <GradientStop Color="#A8070B11" Offset="0.58"/>
                                        <GradientStop Color="#EE070B11" Offset="0.76"/>
                                        <GradientStop Color="#F8070B11" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel x:Name="ProfileActions" Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="5,0,0,0" Opacity="0" IsHitTestVisible="False">
                                <StackPanel.RenderTransform><TranslateTransform X="14"/></StackPanel.RenderTransform>
                                <Button Style="{StaticResource PdaInlineActionStyle}"
                                        ToolTip="Создать копию"
                                        Command="{Binding DataContext.InlineDuplicateProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Viewbox Width="20" Height="20">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M15.5,8.2 V5.8 C15.5,4.81 14.69,4 13.7,4 H6 C5.01,4 4.2,4.81 4.2,5.8 V13.5 C4.2,14.49 5.01,15.3 6,15.3 H8.2"
                                                  Stroke="{StaticResource TextBrush}" StrokeThickness="1.65" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            <Rectangle Canvas.Left="8.2" Canvas.Top="8.2" Width="11.6" Height="11.6" RadiusX="2" RadiusY="2"
                                                       Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button Style="{StaticResource PdaInlineActionStyle}"
                                        ToolTip="Экспортировать"
                                        Command="{Binding DataContext.InlineExportProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Viewbox Width="20" Height="20">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M5,3.8 H12.4 L16.8,8.2 V19.2 C16.8,20.19 15.99,21 15,21 H5 C4.01,21 3.2,20.19 3.2,19.2 V5.6 C3.2,4.61 4.01,3.8 5,3.8 Z M12.2,3.8 V8.4 H16.8"
                                                  Stroke="{StaticResource TextBrush}" StrokeThickness="1.65" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            <Path Data="M10,13 H20 M16.6,9.6 L20,13 L16.6,16.4"
                                                  Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button Style="{StaticResource PdaInlineActionStyle}"
                                        ToolTip="Удалить профиль"
                                        Command="{Binding DataContext.InlineDeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Grid Width="19" Height="19">
                                        <Border Width="19" Height="2" CornerRadius="1" Background="{StaticResource DangerBrush}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform><RotateTransform Angle="45"/></Border.RenderTransform>
                                        </Border>
                                        <Border Width="19" Height="2" CornerRadius="1" Background="{StaticResource DangerBrush}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform><RotateTransform Angle="-45"/></Border.RenderTransform>
                                        </Border>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <DataTemplate.Triggers>
                            <EventTrigger SourceName="ProfileRow" RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.30">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.24"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0" Duration="0:0:0.30">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.08" Value="True"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger SourceName="ProfileRow" RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.28"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.22"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="14" Duration="0:0:0.28"/>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.22" Value="False"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
