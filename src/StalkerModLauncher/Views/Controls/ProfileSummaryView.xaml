<UserControl x:Class="StalkerModLauncher.Views.Controls.ProfileSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <Border Background="{StaticResource FieldBackgroundBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12"
            Margin="0,12,0,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Бинарник"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
                <TextBlock Text="{Binding SelectedProfile.ExecutableRelativePath}"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Аргументы"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
                <TextBlock Text="{Binding SelectedProfile.LaunchArguments}"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Модов в профиле"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
                <TextBlock Text="{Binding SelectedProfile.Mods.Count}"
                           FontSize="13"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="6">
                <TextBlock Text="Наиграно"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
                <TextBlock Text="{Binding SelectedProfile.PlaytimeDisplay}"
                           FontSize="13"
                           Margin="0,4,0,0"/>
                <TextBlock Text="{Binding SelectedProfile.LastPlayedDisplay}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="11"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
