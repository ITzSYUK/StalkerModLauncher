<UserControl x:Class="StalkerModLauncher.Views.Controls.PdaMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StalkerModLauncher.Views.Controls"
             Loaded="PdaMainView_OnLoaded"
             Unloaded="PdaMainView_OnUnloaded"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StalkerModLauncher;component/Themes/PdaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        <ImageBrush x:Key="PdaTopButtonNormalBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="282,215,172,27" Stretch="Fill"/>
        <ImageBrush x:Key="PdaTopButtonHoverBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="455,215,172,27" Stretch="Fill"/>
        <ImageBrush x:Key="PdaTopButtonPressedBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="628,215,172,27" Stretch="Fill"/>
        <ImageBrush x:Key="PdaSmallButtonNormalBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="0,115,179,19" Stretch="Fill"/>
        <ImageBrush x:Key="PdaSmallButtonPressedBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="0,134,179,19" Stretch="Fill"/>
        <ImageBrush x:Key="PdaPowerNormalBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="97,29,34,34" Stretch="Uniform"/>
        <ImageBrush x:Key="PdaPowerHoverBrush"
                    ImageSource="/StalkerModLauncher;component/Resources/PdaUiAtlas.png"
                    ViewboxUnits="Absolute" Viewbox="131,29,34,34" Stretch="Uniform"/>
        <Style x:Key="PdaTopTabStyle" TargetType="Button">
            <Setter Property="Height" Value="31"/>
            <Setter Property="Width" Value="102"/>
            <Setter Property="Padding" Value="11,2"/>
            <Setter Property="Margin" Value="-8,0,0,0"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E9E5D3"/>
            <Setter Property="Background" Value="{StaticResource PdaTopButtonNormalBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="102" Height="31" SnapsToDevicePixels="True">
                            <Path x:Name="Chrome" Data="M12,0 H102 L90,31 H0 Z"
                                  Fill="#17212D" Stroke="#5B6874" StrokeThickness="1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,1,4,1">
                                <ContentPresenter.RenderTransform>
                                    <TranslateTransform X="-2"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Fill" Value="#263442"/>
                                <Setter TargetName="Chrome" Property="Stroke" Value="#8A949D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Fill" Value="#0B1119"/>
                                <Setter TargetName="Chrome" Property="Stroke" Value="#A07832"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaLaunchTabStyle" TargetType="Button">
            <Setter Property="Width" Value="102"/>
            <Setter Property="Height" Value="31"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FFF8E7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="102" Height="31">
                            <Path x:Name="Chrome" Data="M12,0 H102 L90,31 H0 Z" Fill="#C98722" Stroke="#E0A43B" StrokeThickness="1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,1,4,1">
                                <ContentPresenter.RenderTransform>
                                    <TranslateTransform X="-2"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Fill" Value="#D99A30"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Fill" Value="#A96D1D"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaCompactTopTabStyle" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="31"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="-8,0,0,0"/>
            <Setter Property="Foreground" Value="#E9E5D3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="38" Height="31" SnapsToDevicePixels="True">
                            <Path x:Name="Chrome" Data="M12,0 H38 L26,31 H0 Z"
                                  Fill="#17212D" Stroke="#5B6874" StrokeThickness="1"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,2,4,1">
                                <ContentPresenter.RenderTransform>
                                    <TranslateTransform X="-2"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Fill" Value="#263442"/>
                                <Setter TargetName="Chrome" Property="Stroke" Value="#8A949D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Fill" Value="#0B1119"/>
                                <Setter TargetName="Chrome" Property="Stroke" Value="#A07832"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="18,2,8,2"/>
            <Setter Property="FontFamily" Value="Bahnschrift SemiCondensed"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#D6D5C7"/>
            <Setter Property="Background" Value="#141C26"/>
            <Setter Property="BorderBrush" Value="#53606C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Path x:Name="Chrome"
                                  Data="M0,0 H91 L100,9 V30 H0 Z"
                                  Stretch="Fill"
                                  Fill="{TemplateBinding Background}"
                                  Stroke="{TemplateBinding BorderBrush}"
                                  StrokeThickness="1"/>
                            <Ellipse x:Name="Marker" Width="10" Height="10" Margin="7,0,0,0"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Fill="#323D48" Stroke="#77828C" StrokeThickness="1"/>
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F0EEE3"/>
                                <Setter TargetName="Chrome" Property="Fill" Value="#202B37"/>
                                <Setter TargetName="Chrome" Property="Stroke" Value="#7F8A94"/>
                                <Setter TargetName="Marker" Property="Fill" Value="#C5C9C4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Fill" Value="#0B1119"/>
                                <Setter TargetName="Marker" Property="Fill" Value="#CF962C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#151F2B"/>
            <Setter Property="Foreground" Value="#E7E3D3"/>
            <Setter Property="BorderBrush" Value="#4B5967"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="MinHeight" Value="31"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#263442"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#7D8994"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#0B1119"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#182330"/>
            <Setter Property="Foreground" Value="#E7E3D3"/>
            <Setter Property="BorderBrush" Value="#3B4B5B"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,1,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaPowerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{StaticResource PdaPowerNormalBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="{StaticResource PdaPowerHoverBrush}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.7"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaHeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Foreground" Value="#9CA7AD"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EEEBDD"/>
                                <Setter TargetName="Chrome" Property="Background" Value="#22303D"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#667582"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0A111A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaProfileToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#3D1B2632"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#77838B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#6A111923"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.3"/><Setter Property="Cursor" Value="Arrow"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PdaInlineInfoPanelStyle" TargetType="ContentControl">
            <Setter Property="Height" Value="58"/>
            <Setter Property="Padding" Value="14,5,7,5"/>
            <Setter Property="Foreground" Value="#E7E3D3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{DynamicResource FieldBackgroundBrush}"
                                BorderBrush="{DynamicResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Width="1200" Height="823" Background="Transparent">
        <Image Source="/StalkerModLauncher;component/Resources/PdaShell.HD.png"
               Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality" IsHitTestVisible="False"/>

        <Grid Margin="120,98,172,100" ClipToBounds="True" Background="#F0080C13">
            <Grid.Clip>
                <RectangleGeometry Rect="0,0,908,625" RadiusX="11" RadiusY="11"/>
            </Grid.Clip>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#EA101722">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="50"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                <TextBlock Text="S.T.A.L.K.E.R. MOD LAUNCHER" Margin="10,0,8,0" VerticalAlignment="Center"
                           FontFamily="Bahnschrift SemiCondensed" FontSize="12" Foreground="#7E887B"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Запустить" Command="{Binding LaunchCommand}" Style="{StaticResource PdaLaunchTabStyle}"/>
                    <Button Content="Профиль" Style="{StaticResource PdaTopTabStyle}" Click="ProfileTab_OnClick"/>
                    <Button Content="Каталог" Style="{StaticResource PdaTopTabStyle}" Click="CatalogTab_OnClick"/>
                    <Button Content="Журнал" Style="{StaticResource PdaTopTabStyle}" Click="LogButton_OnClick"/>
                    <Button Content="О программе" Style="{StaticResource PdaTopTabStyle}" Click="AboutButton_OnClick"/>
                    <Button Style="{StaticResource PdaCompactTopTabStyle}"
                            Command="{Binding ToggleInterfaceCommand}"
                            ToolTip="Вернуться к обычному интерфейсу">
                        <Viewbox Width="17" Height="17">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="4" Canvas.Top="4" Width="16" Height="12"
                                           Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6"/>
                                <Path Data="M9,20 H15 M12,16 V20 M10,7 L7,10 L10,13 M7,10 H15"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
                <TextBlock x:Name="ClockText" Grid.Column="2" Text="00:00" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="Bahnschrift SemiCondensed" FontSize="14" FontWeight="SemiBold" Foreground="#DFDED0">
                    <TextBlock.RenderTransform>
                        <TranslateTransform Y="2"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <Button Grid.Column="3" Style="{StaticResource PdaPowerButtonStyle}" Click="PowerButton_OnClick"
                        ToolTip="Выключить лаунчер"/>
            </Grid>

            <Border Grid.Row="1" Background="#E00D141E" BorderBrush="#3B4755" BorderThickness="0,1,0,1">
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Grid x:Name="ProfileTypeIcon" Width="20" Height="20" VerticalAlignment="Center">
                        <Canvas Width="17" Height="17">
                            <Canvas.Style>
                                <Style TargetType="Canvas">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Canvas.Style>
                            <Path Data="M8.5,2 L15,5.8 L8.5,9.6 L2,5.8 Z" Fill="#282D1F" Stroke="#C8952D" StrokeThickness="1.2" StrokeLineJoin="Round"/>
                            <Path Data="M2.6,8.7 L8.5,12.2 L14.4,8.7 M2.6,11.7 L8.5,15.2 L14.4,11.7"
                                  Stroke="#C8952D" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                        <Canvas Width="17" Height="17">
                            <Canvas.Style>
                                <Style TargetType="Canvas">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Canvas.Style>
                            <Path Data="M3,5.7 L8.5,2.8 L14,5.7 L8.5,8.6 Z" Fill="#2E301F" Stroke="#C8952D" StrokeThickness="1.2" StrokeLineJoin="Round"/>
                            <Path Data="M3,5.7 V12.2 L8.5,15.4 L14,12.2 V5.7 M8.5,8.6 V15.4"
                                  Stroke="#C8952D" StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Grid>
                    <TextBlock x:Name="PageSectionIcon" Text="◇" Foreground="#D09A2E" FontSize="18"
                               VerticalAlignment="Center" Visibility="Collapsed"/>
                    <TextBlock x:Name="PageTitleText" Grid.Column="1" Text="{Binding SelectedProfile.Name, FallbackValue=Профиль не выбран}"
                               Margin="8,0" VerticalAlignment="Center" FontFamily="Bahnschrift SemiCondensed" FontSize="17"
                               Foreground="#E6E2D1" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="PageStatusText" Grid.Column="2" Text="{Binding ValidationSummary}" MaxWidth="270"
                               VerticalAlignment="Center" FontSize="11" Foreground="#929B88" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#E4090E16"
                    BorderBrush="#465462"
                    BorderThickness="0,0,0,1">
                <Grid Margin="5,2,5,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Список профилей" Width="190"
                            Style="{StaticResource PdaNavButtonStyle}"
                            Click="ProfilesButton_OnClick"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Скриншоты" Width="140" Margin="0,0,4,0"
                                Style="{StaticResource PdaNavButtonStyle}" Click="ScreenshotsButton_OnClick"/>
                        <Button Content="Папка профиля" Width="140" Margin="0,0,4,0"
                                Style="{StaticResource PdaNavButtonStyle}"
                                Command="{Binding OpenProfileFolderCommand}"/>
                        <Button Content="Состояние" Width="140" Margin="0,0,4,0"
                                Style="{StaticResource PdaNavButtonStyle}" Click="StatusButton_OnClick"/>
                        <Button Content="Настройки" Width="140"
                                Style="{StaticResource PdaNavButtonStyle}" Click="SettingsTab_OnClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Background="#F3080D14">
                <Grid x:Name="ProfilePage" Margin="5">
                    <Grid.Style>
                        <Style TargetType="Grid"><Style.Triggers><DataTrigger Binding="{Binding HasProfiles}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style>
                    </Grid.Style>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.08*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ContentControl Grid.Column="0"
                                        Padding="14,5,6,5"
                                        Style="{StaticResource PdaInlineInfoPanelStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="9"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True">
                                                    <Setter Property="Opacity" Value="0.35"/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Базовая игра" Foreground="{StaticResource MutedTextBrush}" FontSize="10"/>
                                    <TextBox Grid.Row="1"
                                             Text="{Binding SelectedProfile.GameInstallPath, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Padding="0,1,0,0"
                                             Background="Transparent"
                                             Foreground="{StaticResource TextBrush}"
                                             VerticalContentAlignment="Center"/>
                                </Grid>
                                <Button Grid.Column="1"
                                        Command="{Binding ChooseGameFolderCommand}"
                                        ToolTip="Выбрать базовую игру"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PdaProfileToolButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True">
                                                    <Setter Property="Opacity" Value="0.35"/>
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Viewbox Width="23" Height="23">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M4,18 V6.5 C4,5.672 4.672,5 5.5,5 H10 L12,7 H18.5 C19.328,7 20,7.672 20,8.5 V18 C20,18.828 19.328,19.5 18.5,19.5 H5.5 C4.672,19.5 4,18.828 4,18 Z"
                                                  Stroke="{StaticResource TextBrush}" StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            <Path Data="M8.5,13 L11,15.5 L16,10.5"
                                                  Stroke="{StaticResource AccentBrush}" StrokeThickness="1.9"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Border Grid.Column="2" Width="1" Height="48" Margin="4,0"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="#52606C"/>
                                <Button Grid.Column="3" Command="{Binding ScanForModsCommand}" Style="{StaticResource PdaProfileToolButtonStyle}"
                                        ToolTip="Найти моды в выбранной папке" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox Width="23" Height="23">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M4,5.5 C4,4.672 4.672,4 5.5,4 H10 L12,6 H18.5 C19.328,6 20,6.672 20,7.5 V10 M11.4,19.5 H5.5 C4.672,19.5 4,18.828 4,18 V8"
                                                  Stroke="{StaticResource TextBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            <Ellipse Canvas.Left="12" Canvas.Top="11" Width="7" Height="7" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7"/>
                                            <Path Data="M17.5,16.5 L21,20" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button Grid.Column="4" Command="{Binding AddModCommand}" Style="{StaticResource PdaProfileToolButtonStyle}"
                                        ToolTip="Добавить папку мода" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Viewbox Width="23" Height="23">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M4,18 V6.5 C4,5.672 4.672,5 5.5,5 H10 L12,7 H18.5 C19.328,7 20,7.672 20,8.5 V18 C20,18.828 19.328,19.5 18.5,19.5 H5.5 C4.672,19.5 4,18.828 4,18 Z"
                                                  Stroke="{StaticResource TextBrush}" StrokeThickness="1.7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                            <Path Data="M12,10 V16 M9,13 H15" Stroke="{StaticResource AccentBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </ContentControl>

                        <ContentControl Grid.Column="2" Style="{StaticResource PdaInlineInfoPanelStyle}">
                            <Grid>
                                <Grid.Resources>
                                    <Style x:Key="InlineSummaryLabelStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                    <Style x:Key="InlineSummaryValueStyle" TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Margin" Value="0,2,0,0"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </Grid.Resources>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                    <ColumnDefinition Width="0.75*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,9,0">
                                    <TextBlock Text="Бинарник" Style="{StaticResource InlineSummaryLabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedProfile.ExecutableRelativePath}" Style="{StaticResource InlineSummaryValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,9,0">
                                    <TextBlock Text="Аргументы" Style="{StaticResource InlineSummaryLabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedProfile.LaunchArguments}" Style="{StaticResource InlineSummaryValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,9,0">
                                    <TextBlock Text="Модов" Style="{StaticResource InlineSummaryLabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedProfile.Mods.Count}" Style="{StaticResource InlineSummaryValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Наиграно" Style="{StaticResource InlineSummaryLabelStyle}"/>
                                    <TextBlock Text="{Binding SelectedProfile.PlaytimeDisplay}"
                                               Margin="0,2,0,0"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding SelectedProfile.LastPlayedDisplay}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </ContentControl>

                    </Grid>
                    <controls:ModPanelView Grid.Row="1"
                                           ShowStandaloneToggle="False"
                                           UseCompactHeader="True"
                                           UsePdaTheme="True"/>
                </Grid>

                <StackPanel x:Name="EmptyProfilePage" Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasProfiles}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style>
                    </StackPanel.Style>
                    <TextBlock Text="ПРОФИЛЕЙ ПОКА НЕТ" FontFamily="Bahnschrift SemiCondensed" FontSize="22" Foreground="#E4E0CF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Создайте профиль, добавьте игру и подключите нужные моды." Margin="0,7,0,14" TextAlignment="Center" TextWrapping="Wrap" Foreground="#929B88"/>
                    <Button Content="Создать первый профиль" Command="{Binding NewProfileCommand}" HorizontalAlignment="Center" Padding="18,7"/>
                </StackPanel>

                <ContentControl x:Name="PageHost" Visibility="Collapsed"/>

                <Border x:Name="DrawerDim" Background="#A0000000" Opacity="0" Visibility="Collapsed"
                        MouseLeftButtonDown="DrawerDim_OnMouseLeftButtonDown" Panel.ZIndex="10"/>
                <Border x:Name="ProfileDrawer" Width="315" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                        Background="Transparent" Opacity="0" Visibility="Collapsed" Panel.ZIndex="11">
                    <Border.RenderTransform><TranslateTransform x:Name="DrawerTransform" X="-325"/></Border.RenderTransform>
                    <controls:PdaProfileDrawerView ProfileSelected="ProfileDrawer_OnProfileSelected"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
