<UserControl x:Class="StalkerModLauncher.Views.Controls.PdaProfileCreationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#080D14">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StalkerModLauncher;component/Themes/PdaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PdaProfileTypeCardStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="#0A1019"/>
                <Setter Property="BorderBrush" Value="#3B4755"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Card"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="13" Height="13" VerticalAlignment="Top" Margin="0,3,0,0">
                                        <Ellipse x:Name="Outer" Fill="#080D14" Stroke="#75818A" StrokeThickness="1"/>
                                        <Ellipse x:Name="Inner" Width="6" Height="6" Fill="{StaticResource AccentBrush}" Visibility="Collapsed"/>
                                    </Grid>
                                    <ContentPresenter Grid.Column="1"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Card" Property="Background" Value="#172230"/>
                                    <Setter TargetName="Card" Property="BorderBrush" Value="#687684"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Card" Property="Background" Value="#1D2B39"/>
                                    <Setter TargetName="Card" Property="BorderBrush" Value="#8B7850"/>
                                    <Setter TargetName="Inner" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="{Binding StepTitle}"
                           FontFamily="Bahnschrift SemiCondensed"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Message}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMessageWarning}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Отмена" Click="CancelButton_OnClick" Margin="0,0,6,0"/>
                <Button Content="Назад" Command="{Binding BackCommand}" Margin="0,0,6,0"/>
                <Button Content="Далее" Command="{Binding NextCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PdaBaseButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNextVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Создать" Command="{Binding FinishCommand}" Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFinishVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="#0D141E"
                BorderBrush="#3B4755"
                BorderThickness="1"
                Padding="13">
            <Grid>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStepOne}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="ВЫБЕРИТЕ ВАРИАНТ"
                               FontFamily="Bahnschrift SemiCondensed"
                               FontSize="16"
                               Margin="0,0,0,9"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0"
                                     GroupName="PdaProfileType"
                                     IsChecked="{Binding IsOverlay}"
                                     Style="{StaticResource PdaProfileTypeCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Мод поверх базовой игры" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Отдельная папка игры и один или несколько модов."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Grid.Column="2"
                                     GroupName="PdaProfileType"
                                     IsChecked="{Binding IsStandalone}"
                                     Style="{StaticResource PdaProfileTypeCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Автономная игра или мод" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Готовая сборка со своим движком и игровыми файлами."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                    <TextBlock Text="Название профиля" Foreground="{StaticResource MutedTextBrush}" Margin="0,18,0,4"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="{Binding ProfileTypeDescription}"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStepTwo}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStandalone}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Папка базовой игры" Foreground="{StaticResource MutedTextBrush}"/>
                        <Grid Grid.Row="1" Margin="0,4,0,10"
                              AllowDrop="True"
                              PreviewDragOver="GamePath_OnPreviewDragOver"
                              PreviewDrop="GamePath_OnPreviewDrop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding GamePath}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Выбрать" Command="{Binding BrowseGameCommand}" Margin="7,0,0,0"/>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Моды" Foreground="{StaticResource MutedTextBrush}"/>
                            <TextBlock Grid.Column="1" Text="Ниже — больший приоритет"
                                       Foreground="{StaticResource DisabledTextBrush}" FontSize="10"/>
                        </Grid>
                        <Border Grid.Row="3"
                                Background="#080D14"
                                BorderBrush="#3B4755"
                                BorderThickness="1"
                                Margin="0,0,0,8"
                                AllowDrop="True"
                                PreviewDragOver="ModsList_OnPreviewDragOver"
                                PreviewDrop="ModsList_OnPreviewDrop">
                            <Grid ClipToBounds="True">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Mods}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="10,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding SourcePath}" Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="Убрать"
                                                            Command="{Binding DataContext.RemoveModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="8,3"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="Перетащите сюда папки модов или нажмите «Добавить мод»."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasNoMods}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <Button Grid.Row="4" Content="Добавить мод" Command="{Binding AddModCommand}" HorizontalAlignment="Left"/>
                    </Grid>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStandalone}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Выберите или переместите мышкой корневую директорию мода или игры"
                                   FontFamily="Bahnschrift SemiCondensed" FontSize="16" Margin="0,0,0,12"/>
                        <Grid AllowDrop="True"
                              PreviewDragOver="StandalonePath_OnPreviewDragOver"
                              PreviewDrop="StandalonePath_OnPreviewDrop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding StandalonePath, Mode=OneWay}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Выбрать папку" Command="{Binding BrowseStandaloneCommand}" Margin="7,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStepThree}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Background="#111925" BorderBrush="#3B4755" BorderThickness="1" Padding="10" Margin="0,0,0,11">
                        <StackPanel>
                            <TextBlock Text="{Binding ProfileTypeLabel}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SourceSummary}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Файл запуска" Foreground="{StaticResource MutedTextBrush}"/>
                    <Grid Margin="0,4,0,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ExecutableRelativePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Обзор..." Command="{Binding BrowseExecutableCommand}" Margin="7,0,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding ExecutableDetectionMessage}" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,9"/>
                    <TextBlock Text="Параметры запуска" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Text="{Binding LaunchArguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,9"/>
                    <TextBlock Text="Перед запуском лаунчер ещё раз проверит итоговый бинарник и источники файлов."
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
