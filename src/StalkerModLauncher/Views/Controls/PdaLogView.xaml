<UserControl x:Class="StalkerModLauncher.Views.Controls.PdaLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#080D14">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StalkerModLauncher;component/Themes/PdaTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <TextBlock Text="ЖУРНАЛ ЛАУНЧЕРА" FontFamily="Bahnschrift SemiCondensed" FontSize="16" Foreground="#E2DDC9" Margin="0,0,0,7"/>
        <TextBox Grid.Row="1"
                 Text="{Binding ActivityLog.Text, Mode=OneWay}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#060A10"
                 BorderBrush="#3B4755"
                 Foreground="#CAC8B8"
                 FontFamily="Consolas"
                 FontSize="11"/>
    </Grid>
</UserControl>
