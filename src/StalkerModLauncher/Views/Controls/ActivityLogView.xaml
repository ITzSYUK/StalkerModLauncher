<UserControl x:Class="StalkerModLauncher.Views.Controls.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10"
            Visibility="{Binding ActivityLog.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Журнал"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Row="1"
                     Margin="0,6,0,0"
                     Text="{Binding ActivityLog.Text, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"/>
        </Grid>
    </Border>
</UserControl>
