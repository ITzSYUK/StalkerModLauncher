<Window x:Class="StalkerModLauncher.Views.ProfileCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание профиля"
        Width="760"
        Height="590"
        MinWidth="650"
        MinHeight="500"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterOwner"
        SourceInitialized="Window_OnSourceInitialized">
    <Window.Resources>
        <Style x:Key="ProfileTypeCardStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="{StaticResource FieldBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Indicator"
                                        Width="15"
                                        Height="15"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource MutedTextBrush}"
                                        BorderThickness="2"
                                        VerticalAlignment="Top"
                                        Margin="0,3,0,0">
                                    <Ellipse x:Name="IndicatorFill"
                                             Fill="{StaticResource AccentBrush}"
                                             Margin="2"
                                             Opacity="0"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#696E54"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#303423"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Card" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Indicator" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="IndicatorFill" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding StepTitle}"
                   FontSize="24"
                   FontWeight="SemiBold"/>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="18"
                Margin="0,14,0,12">
            <Grid>
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsStepOne}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Как будет запускаться профиль?"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0"
                                     GroupName="ProfileType"
                                     IsChecked="{Binding IsOverlay}"
                                     Style="{StaticResource ProfileTypeCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Мод поверх базовой игры"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Отдельная папка игры и один или несколько модов."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Grid.Column="2"
                                     GroupName="ProfileType"
                                     IsChecked="{Binding IsStandalone}"
                                     Style="{StaticResource ProfileTypeCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Автономная игра или мод"
                                           FontSize="15"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Готовая сборка со своим движком и игровыми файлами."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </RadioButton>
                    </Grid>
                    <TextBlock Text="Название профиля"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,22,0,0"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0"/>
                </StackPanel>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsStepTwo}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers><DataTrigger Binding="{Binding IsStandalone}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Папка базовой игры" Foreground="{StaticResource MutedTextBrush}"/>
                        <Grid Margin="0,5,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Text="{Binding GamePath}" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="Выбрать" Command="{Binding BrowseGameCommand}" Margin="8,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Моды — нижний мод имеет более высокий приоритет" Foreground="{StaticResource MutedTextBrush}"/>
                        <ListBox ItemsSource="{Binding Mods}" Height="230" Margin="0,5,0,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SourcePath}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Убрать" Command="{Binding DataContext.RemoveModCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Добавить папку мода" Command="{Binding AddModCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding IsStandalone}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Папка автономной игры или мода"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Выберите корневую папку готовой сборки. В ней должны находиться движок, игровые файлы и запускаемый EXE."
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,5,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Text="{Binding StandalonePath, Mode=OneWay}"
                                     IsReadOnly="True"
                                     MinHeight="38"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Выбрать папку"
                                    Command="{Binding BrowseStandaloneCommand}"
                                    Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers><DataTrigger Binding="{Binding IsStepThree}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Запускаемый файл" Foreground="{StaticResource MutedTextBrush}"/>
                    <Grid Margin="0,5,0,14">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ExecutableRelativePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Обзор..." Command="{Binding BrowseExecutableCommand}" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock Text="Параметры запуска" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Text="{Binding LaunchArguments, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,14"/>
                    <TextBlock Text="Перед первым запуском лаунчер проверит итоговый бинарник, источники файлов и workspace."
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Message}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,16,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Назад" Command="{Binding BackCommand}" Margin="0,0,8,0"/>
                <Button Content="Далее" Command="{Binding NextCommand}" Margin="0,0,8,0"/>
                <Button Content="Создать" Command="{Binding FinishCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
