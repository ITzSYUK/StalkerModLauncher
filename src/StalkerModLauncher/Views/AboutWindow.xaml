<Window x:Class="StalkerModLauncher.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе"
        Width="700"
        Height="680"
        MinWidth="540"
        MinHeight="480"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="AboutWindow_OnSourceInitialized">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="S.T.A.L.K.E.R. Mod Launcher"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Что делает лаунчер"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="21">
                    Профиль — это сохранённый набор настроек для одной сборки: откуда взять игру и моды, в каком порядке их применить и какой EXE запустить. Можно держать несколько независимых профилей и переключаться между ними, не меняя файлы установленной игры или папки модов.
                </TextBlock>

                <TextBlock Text="Как начать"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="21">
                    Нажмите «Создать», задайте имя и выберите тип профиля. Для обычного мода укажите папку базовой игры, затем добавьте папки модов в нужном порядке. Для готовой отдельной сборки выберите «Автономный мод» и укажите одну её корневую папку. Мастер сам попробует найти подходящий EXE; при необходимости его всегда можно выбрать вручную в «Настройках».
                </TextBlock>

                <TextBlock Text="Два типа профилей"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="21">
                    Обычный профиль нужен, когда моды накладываются поверх "чистой" установленной версии игры. Лаунчер собирает для него отдельную рабочую среду. "Автономный мод" подразумевает под собой готовую сборку модификаций, не требующую оригинальной игры. Такой профиль запускает мод из его собственной директории, не создавая отдельную рабочую среду.
                </TextBlock>

                <TextBlock Text="Рабочая среда (workspace)"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="21">
                    Workspace — отдельная папка, в которой лаунчер объединяет игру и включённые моды для обычного профиля. Большие исходные файлы подключаются ссылками, поэтому игра не копируется целиком на каждый профиль. Все изменения, профильные настройки, логи и сохранения остаются внутри этой рабочей среды; оригинальная игра не редактируется.
                </TextBlock>

                <TextBlock Text="F.A.Q."
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Как работает порядок модов"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="21">
                    Моды ниже в списке имеют больший приоритет и могут заменить файлы модов выше. Это нормальный способ установить патч поверх основной версии мода. Порядок можно менять перетаскиванием или кнопками в строке мода. При следующем запуске workspace будет собран заново с новым порядком.
                </TextBlock>

                <TextBlock Text="Почему workspace может казаться большим"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="21">
                    Проводник учитывает размер файлов, связанных с workspace, как будто каждый из них лежит там отдельной копией. На деле hard link не дублирует данные на диске. В окне «Состояние» показаны и размер, который видит игра, и приблизительно занятое место.
                </TextBlock>

                <TextBlock Text="Где искать сохранения и логи"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="21">
                    У обычного профиля они находятся в workspace\userdata, поэтому сохранения разных профилей не смешиваются. У автономного мода место определяет сама сборка; кнопка «Состояние» покажет найденные сохранения и последний лог.
                </TextBlock>

                <TextBlock Text="Что делает «Удалить профиль»"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="21">
                    Для обычного профиля удаляются только запись профиля и его workspace с профильными настройками, логами и сохранениями. Папки игры и модов не затрагиваются. Для автономного профиля папка автономной сборки тоже остаётся на месте.
                </TextBlock>

                <TextBlock Text="Если игра не запускается"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="21">
                    Откройте «Состояние»: там собраны проверка путей, выбранный EXE, последний лог и crash dump. Сначала убедитесь, что все папки существуют, а EXE принадлежит игре или включённому моду. Для оригинальной Shadow of Chernobyl это обычно bin\XR_3DA.exe, для OGSR-сборок часто bin_x64\xrEngine.exe.
                </TextBlock>

                <TextBlock Text="Можно ли убрать мод без удаления его файлов"
                           FontWeight="SemiBold"
                           Margin="0,0,0,3"/>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" LineHeight="21">
                    Да. «Убрать» исключает мод только из этого профиля. Исходная папка мода на диске остаётся нетронутой.
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0"
                      IsChecked="{Binding DontShowAgain, RelativeSource={RelativeSource AncestorType=Window}}"
                      Content="Не показывать при запуске"
                      FontSize="12"
                      Foreground="{StaticResource MutedTextBrush}"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Закрыть"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CloseButton_OnClick"
                    MinWidth="100"/>
        </Grid>
    </Grid>
</Window>
