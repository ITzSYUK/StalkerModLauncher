<Window x:Class="StalkerModLauncher.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StalkerModLauncher.Views.Controls"
        Title="О программе"
        Width="700"
        Height="680"
        MinWidth="540"
        MinHeight="480"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="AboutWindow_OnSourceInitialized">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="S.T.A.L.K.E.R. Mod Launcher"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="VersionTextBlock"
                           Margin="0,3,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    x:Name="CheckUpdatesButton"
                    Content="Проверить обновления"
                    MinWidth="160"
                    VerticalAlignment="Center"
                    Click="CheckUpdatesButton_OnClick"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <controls:AboutContentView Margin="0,0,10,0"/>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0"
                      IsChecked="{Binding DontShowAgain, RelativeSource={RelativeSource AncestorType=Window}}"
                      Content="Не показывать при запуске"
                      FontSize="12"
                      Foreground="{StaticResource MutedTextBrush}"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="Интерфейс КПК"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="PdaInterfaceButton_OnClick"
                    ToolTip="Открыть альтернативный интерфейс в стиле КПК"
                    MinWidth="130"/>
        </Grid>
    </Grid>
</Window>
