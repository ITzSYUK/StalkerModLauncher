<Window x:Class="StalkerModLauncher.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Доступно обновление"
        Width="460"
        Height="235"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Доступна новая версия лаунчера"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,16">
            <TextBlock TextWrapping="Wrap"
                       Text="Новая версия опубликована на GitHub. Скачивание откроется в браузере."/>
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Установлена:" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Grid.Column="1" x:Name="CurrentVersionTextBlock" Margin="10,0,0,0"/>
            </Grid>
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Доступна:" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBlock Grid.Column="1" x:Name="LatestVersionTextBlock" Margin="10,0,0,0" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Позже"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Click="LaterButton_OnClick"/>
            <Button Content="Скачать с GitHub"
                    MinWidth="150"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="DownloadButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
