<Window x:Class="StalkerModLauncher.Views.PdaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StalkerModLauncher.Views.Controls"
        Title="S.T.A.L.K.E.R. Mod Launcher - PDA"
        Width="1200"
        Height="823"
        MinWidth="1200"
        MinHeight="823"
        MaxWidth="1200"
        MaxHeight="823"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_OnMouseLeftButtonDown">
    <controls:PdaMainView x:Name="PdaView"
                          ProfileHealthRequested="ProfileHealthButton_OnClick"
                          ProfileSettingsRequested="EditProfileButton_OnClick"
                          ScreenshotsRequested="ScreenshotsButton_OnClick"
                          ModCatalogRequested="ModCatalogButton_OnClick"
                          AboutRequested="AboutButton_OnClick"
                          LogRequested="LogButton_OnClick"/>
</Window>
