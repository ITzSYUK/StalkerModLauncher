<Window x:Class="StalkerModLauncher.Views.ScreenshotFullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр скриншота"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        Background="#050608"
        Foreground="#F0E8C8"
        ShowInTaskbar="False"
        KeyDown="Window_OnKeyDown"
        PreviewMouseWheel="Window_OnPreviewMouseWheel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="64"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
                Content="◀"
                Command="{Binding GoPreviousCommand}"
                IsEnabled="{Binding CanGoPrevious}"
                Width="46"
                Height="64"
                Padding="0"
                FontSize="24"
                VerticalAlignment="Center"
                Background="#AA111820"
                BorderBrush="#66717D"
                BorderThickness="1"/>

        <Image Grid.Column="1"
               Source="{Binding SelectedScreenshot}"
               Stretch="Uniform"
               Margin="8"
               MouseLeftButtonDown="Image_OnMouseLeftButtonDown">
            <Image.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Скопировать в буфер обмена"
                              Click="CopyScreenshotMenuItem_OnClick"/>
                </ContextMenu>
            </Image.ContextMenu>
        </Image>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Content="×"
                    Width="42"
                    Height="42"
                    Padding="0"
                    Margin="0,12,12,0"
                    HorizontalAlignment="Right"
                    FontSize="22"
                    Background="#AA111820"
                    BorderBrush="#66717D"
                    BorderThickness="1"
                    Click="CloseButton_OnClick"/>
            <Button Grid.Row="1"
                    Content="▶"
                    Command="{Binding GoNextCommand}"
                    IsEnabled="{Binding CanGoNext}"
                    Width="46"
                    Height="64"
                    Padding="0"
                    FontSize="24"
                    VerticalAlignment="Center"
                    Background="#AA111820"
                    BorderBrush="#66717D"
                    BorderThickness="1"/>
        </Grid>

        <TextBlock Grid.Column="1"
                   Text="Esc — закрыть   •   Колесо мыши или стрелки — следующий скриншот"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,12"
                   Padding="10,5"
                   Foreground="#C9C7B8"
                   Background="#AA111820"
                   FontSize="12"/>
    </Grid>
</Window>
