<Window x:Class="StalkerModLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:StalkerModLauncher.Views.Controls"
        mc:Ignorable="d"
        Title="S.T.A.L.K.E.R. Mod Launcher"
        MinWidth="1280"
        MinHeight="560"
        Width="1280"
        Height="760"
        Background="{StaticResource WindowBackgroundBrush}"
        SourceInitialized="Window_OnSourceInitialized"
        Closing="Window_OnClosing"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LaunchCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewProfileCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateProfileCommand}"/>
    </Window.InputBindings>
    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding ActivityLog.RowHeight}"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:LauncherBrand Grid.Row="0"
                                        Margin="0,0,0,10"
                                        MouseDown="Title_MouseDown"/>

                <controls:ProfileSidebarView Grid.Row="1"
                                             ModCatalogRequested="ModCatalogButton_OnClick"/>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <Grid>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProfiles}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <controls:GamePathBar Grid.Row="0"
                                              Margin="0,0,0,10"/>

                        <controls:ProfileHeaderView Grid.Row="1"
                                                    ProfileHealthRequested="ProfileHealthButton_OnClick"
                                                    ProfileSettingsRequested="EditProfileButton_OnClick"
                                                    ScreenshotsRequested="ScreenshotsButton_OnClick"/>

                        <controls:ProfileSummaryView Grid.Row="2"/>

                        <controls:ModPanelView Grid.Row="3"
                                               Grid.RowSpan="2"/>
                    </Grid>

                    <Border Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="28">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasProfiles}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <StackPanel Width="420"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Профилей пока нет"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="Профиль хранит список модов, порядок загрузки, выбранный EXE, сохранения и рабочую среду."
                                           FontSize="14"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           LineHeight="21"
                                           Margin="0,0,0,22"/>
                                <Button Content="Создать первый профиль"
                                        Command="{Binding NewProfileCommand}"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Padding="18,10"
                                        MinWidth="220"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Height="3"
                      Margin="0,3,0,3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{StaticResource StrokeBrush}"
                      ResizeDirection="Rows"
                      Visibility="{Binding ActivityLog.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <controls:ActivityLogView Grid.Row="2"/>
    </Grid>
</Window>
