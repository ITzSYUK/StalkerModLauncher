<Window x:Class="StalkerModLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="S.T.A.L.K.E.R. Mod Launcher"
        MinWidth="1280"
        MinHeight="560"
        Width="1280"
        Height="760"
        Background="{StaticResource WindowBackgroundBrush}"
        SourceInitialized="Window_OnSourceInitialized"
        Closing="Window_OnClosing"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="InlineModActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style x:Key="ProfileActionsToggleButtonStyle"
               TargetType="ToggleButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Viewbox x:Name="CollapsedArrow"
                                         Width="14"
                                         Height="18">
                                    <Path Fill="{StaticResource TextBrush}"
                                          Data="M335.99,42.42 L336,468.99 C336,492.44 316.98,511.45 293.54,511.45 C282.48,511.45 272.42,507.23 264.86,500.3 L15.37,293.87 C-2.67,278.95 -5.19,252.21 9.73,234.17 C11.22,232.37 12.85,230.71 14.55,229.21 L265.69,10.42 C283.35,-4.96 310.16,-3.09 325.54,14.57 C332.54,22.61 335.97,32.53 335.99,42.42 Z"/>
                                </Viewbox>
                                <Viewbox x:Name="ExpandedArrow"
                                         Width="14"
                                         Height="18"
                                         Opacity="0">
                                    <Path Fill="{StaticResource TextBrush}"
                                          Data="M0,469 V42.42 C0.02,32.53 3.46,22.61 10.45,14.57 C25.84,-3.09 52.65,-4.96 70.31,10.42 L321.46,229.2 C323.15,230.71 324.78,232.37 326.27,234.17 C341.19,252.21 338.67,278.95 320.63,293.87 L71.14,500.3 C63.58,507.23 53.52,511.46 42.46,511.46 C19.02,511.46 0,492.44 0,469 Z"/>
                                </Viewbox>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5C604F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CollapsedArrow" Property="Opacity" Value="0"/>
                                <Setter TargetName="ExpandedArrow" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProfileHeaderIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#5C604F"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InlineProfileActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="29"/>
            <Setter Property="Height" Value="29"/>
            <Setter Property="MinHeight" Value="29"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
        </Style>
        <Style x:Key="ProfileListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="0">
                            <Grid ClipToBounds="True">
                                <ContentPresenter Margin="12,8"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                <Border x:Name="ActionShade"
                                        Background="#B3000000"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <StackPanel x:Name="ProfileActions"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,7,0"
                                            Opacity="0"
                                            IsHitTestVisible="False">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform X="18"/>
                                    </StackPanel.RenderTransform>
                                    <Button Style="{StaticResource InlineProfileActionButtonStyle}"
                                            Command="{Binding DataContext.InlineDuplicateProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Создать копию профиля">
                                        <Viewbox Width="19" Height="19">
                                            <Canvas Width="24" Height="24">
                                                <Rectangle Canvas.Left="8"
                                                           Canvas.Top="8"
                                                           Width="11"
                                                           Height="11"
                                                           RadiusX="2"
                                                           RadiusY="2"
                                                           Stroke="{StaticResource TextBrush}"
                                                           StrokeThickness="1.8"/>
                                                <Path Data="M16,8 V6 C16,4.895 15.105,4 14,4 H6 C4.895,4 4,4.895 4,6 V14 C4,15.105 4.895,16 6,16 H8"
                                                      Stroke="{StaticResource TextBrush}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Button>
                                    <Button Style="{StaticResource InlineProfileActionButtonStyle}"
                                            Command="{Binding DataContext.InlineDeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Удалить профиль">
                                        <Grid Width="16" Height="16">
                                            <Border Width="17"
                                                    Height="2"
                                                    CornerRadius="1"
                                                    Background="{StaticResource DangerBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <RotateTransform Angle="45"/>
                                                </Border.RenderTransform>
                                            </Border>
                                            <Border Width="17"
                                                    Height="2"
                                                    CornerRadius="1"
                                                    Background="{StaticResource DangerBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <RotateTransform Angle="-45"/>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#3A3325"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.45"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.38">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.12" Value="True"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.28"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="18"
                                                         Duration="0:0:0.34">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.28" Value="False"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ModListViewItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Grid ClipToBounds="True">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <GridViewRowPresenter Grid.Row="0"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding OverlaySummary}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="9"
                                               Margin="86,0,0,2"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding OverlayDetails}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOverlayInfo}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Border x:Name="ActionShade"
                                        Background="#B3000000"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>

                                <Grid x:Name="ActionRail"
                                      Width="38"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,2,0"
                                      Background="Transparent"
                                      ClipToBounds="True"
                                      Opacity="0"
                                      IsHitTestVisible="False">
                                    <Grid Width="270" HorizontalAlignment="Right">
                                        <StackPanel x:Name="ActionButtons"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,40,0"
                                                    Opacity="0">
                                            <Button Content="Убрать"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineRemoveModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Выше"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineMoveModUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Ниже"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineMoveModDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Открыть"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineOpenModFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <Border Width="38"
                                                HorizontalAlignment="Right"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Grid>
                                                <Viewbox x:Name="LeftChevron"
                                                         Width="17"
                                                         Height="21">
                                                    <Path Fill="{StaticResource TextBrush}"
                                                          Data="M335.99,42.42 L336,468.99 C336,492.44 316.98,511.45 293.54,511.45 C282.48,511.45 272.42,507.23 264.86,500.3 L15.37,293.87 C-2.67,278.95 -5.19,252.21 9.73,234.17 C11.22,232.37 12.85,230.71 14.55,229.21 L265.69,10.42 C283.35,-4.96 310.16,-3.09 325.54,14.57 C332.54,22.61 335.97,32.53 335.99,42.42 Z"/>
                                                </Viewbox>
                                                <Viewbox x:Name="RightChevron"
                                                         Width="17"
                                                         Height="21"
                                                         Opacity="0">
                                                    <Path Fill="{StaticResource TextBrush}"
                                                          Data="M0,469 V42.42 C0.02,32.53 3.46,22.61 10.45,14.57 C25.84,-3.09 52.65,-4.96 70.31,10.42 L321.46,229.2 C323.15,230.71 324.78,232.37 326.27,234.17 C341.19,252.21 338.67,278.95 320.63,293.87 L71.14,500.3 C63.58,507.23 53.52,511.46 42.46,511.46 C19.02,511.46 0,492.44 0,469 Z"/>
                                                </Viewbox>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource PanelAltBrush}"/>
                                <Setter TargetName="ActionRail" Property="Opacity" Value="1"/>
                                <Setter TargetName="ActionRail" Property="IsHitTestVisible" Value="True"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="#3A3325"/>
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <EventTrigger SourceName="ActionRail" RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionRail"
                                                         Storyboard.TargetProperty="Width"
                                                         To="270"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         BeginTime="0:0:0.10"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.65"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="LeftChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.22"/>
                                        <DoubleAnimation Storyboard.TargetName="RightChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.22"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger SourceName="ActionRail" RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionRail"
                                                         Storyboard.TargetProperty="Width"
                                                         To="38"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="LeftChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="RightChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.30"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LaunchCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewProfileCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateProfileCommand}"/>
    </Window.InputBindings>
    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding LogRowHeight}"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel Cursor="Hand"
                                MouseDown="Title_MouseDown"
                                HorizontalAlignment="Center">
                        <TextBlock Text="S.T.A.L.K.E.R."
                                   FontSize="25"
                                   FontWeight="Black"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MOD LAUNCHER"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,1,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="12,12,12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Профили"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       ToolTip="Профили можно перетаскивать для изменения порядка"
                                       ToolTipService.InitialShowDelay="700"
                                       ToolTipService.ShowDuration="5000"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <Button Command="{Binding NewProfileCommand}"
                                        Style="{StaticResource ProfileHeaderIconButtonStyle}"
                                        ToolTip="Создать профиль"
                                        Margin="0,0,3,0">
                                    <Viewbox Width="26" Height="26">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Data="M11,13 V16 C11,16.283 11.096,16.521 11.288,16.713 C11.48,16.905 11.717,17.001 12,17 C12.283,16.999 12.52,16.903 12.713,16.712 C12.906,16.521 13.001,16.283 13,16 V13 H16 C16.283,13 16.521,12.904 16.713,12.712 C16.905,12.52 17.001,12.283 17,12 C16.999,11.717 16.903,11.48 16.712,11.288 C16.521,11.096 16.283,11 16,11 H13 V8 C13,7.717 12.904,7.479 12.712,7.288 C12.52,7.097 12.283,7.001 12,7 C11.717,6.999 11.48,7.095 11.288,7.288 C11.096,7.481 11,7.718 11,8 V11 H8 C7.717,11 7.479,11.096 7.288,11.288 C7.097,11.48 7.001,11.717 7,12 C6.999,12.283 7.095,12.52 7.288,12.713 C7.481,12.906 7.718,13.001 8,13 Z M5,21 C4.45,21 3.979,20.804 3.588,20.413 C3.197,20.022 3.001,19.551 3,19 V5 C3,4.45 3.196,3.979 3.588,3.588 C3.98,3.197 4.451,3.001 5,3 H19 C19.55,3 20.021,3.196 20.413,3.588 C20.805,3.98 21.001,4.451 21,5 V19 C21,19.55 20.804,20.021 20.413,20.413 C20.022,20.805 19.551,21.001 19,21 Z"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                                <Button Command="{Binding ImportProfileCommand}"
                                        Style="{StaticResource ProfileHeaderIconButtonStyle}"
                                        ToolTip="Импортировать профиль">
                                    <Viewbox Width="26" Height="26">
                                        <Canvas Width="24" Height="24">
                                            <Rectangle Canvas.Left="4"
                                                       Canvas.Top="3"
                                                       Width="16"
                                                       Height="18"
                                                       RadiusX="3"
                                                       RadiusY="3"
                                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                       StrokeThickness="1.7"/>
                                            <Path Data="M12,6 V15 M8.5,11.5 L12,15 L15.5,11.5 M8,18 H16"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="ProfilesList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 ItemContainerStyle="{StaticResource ProfileListBoxItemStyle}"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="ProfilesList_OnPreviewMouseLeftButtonDown"
                                 MouseMove="ProfilesList_OnMouseMove"
                                 DragOver="ProfilesList_OnDragOver"
                                 DragLeave="ProfilesList_OnDragLeave"
                                 Drop="ProfilesList_OnDrop"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   LineHeight="17"
                                                   MaxHeight="51"/>
                                        <TextBlock Text="Запущен"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,-1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="2"
                                Content="{Binding LogToggleText}"
                                Command="{Binding ToggleLogCommand}"
                                Margin="12,10,12,12"
                                Padding="6,4"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True">
                                        <Setter Property="Opacity" Value="0.35"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Папка игры"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBox Grid.Row="1"
                                         Text="{Binding SelectedProfile.GameInstallPath, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Padding="0,2,0,0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                            <Button Grid.Column="1"
                                    Content="Выбрать игру"
                                    Command="{Binding ChooseGameFolderCommand}"
                                    Margin="12,0,0,0"
                                    MinWidth="120"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              ClipToBounds="True">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Margin" Value="0,0,160,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=ProfileActionsToggle}"
                                                     Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                            To="0,0,728,0"
                                                                            Duration="0:0:0.46">
                                                            <ThicknessAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </ThicknessAnimation.EasingFunction>
                                                        </ThicknessAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                                            To="0,0,160,0"
                                                                            Duration="0:0:0.42">
                                                            <ThicknessAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseInOut"/>
                                                            </ThicknessAnimation.EasingFunction>
                                                        </ThicknessAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="12"
                                    Height="12"
                                    CornerRadius="6"
                                    VerticalAlignment="Top"
                                    Margin="0,8,10,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGameValid}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue=Профиль}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           LineHeight="28"
                                           MaxHeight="56"/>
                                <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Margin="0,1,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Мод поверх базовой игры"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True">
                                                    <Setter Property="Text" Value="Автономный мод"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ValidationSummary}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,1,0,0"
                                           TextWrapping="Wrap"
                                           LineHeight="18"
                                           MaxHeight="54"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="0"
                              Grid.ColumnSpan="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Panel.ZIndex="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    ClipToBounds="True"
                                    Margin="0,0,4,8"
                                    Width="0"
                                    Opacity="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, ElementName=ProfileActionsToggle}" Value="True">
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                             To="564"
                                                                             Duration="0:0:0.46">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="1"
                                                                             BeginTime="0:0:0.08"
                                                                             Duration="0:0:0.30"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                             To="0"
                                                                             Duration="0:0:0.42">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseInOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="0"
                                                                             Duration="0:0:0.26"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Width="564"
                                            Height="38"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top">
                                    <Button Content="Состояние"
                                            Click="ProfileHealthButton_OnClick"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Настройки"
                                            Click="EditProfileButton_OnClick"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Экспорт"
                                            Command="{Binding ExportProfileCommand}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Папка профиля"
                                            Command="{Binding OpenProfileFolderCommand}"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Скриншоты"
                                            Click="ScreenshotsButton_OnClick"
                                            Margin="0,0,8,0"/>
                                    <Button Content="Заметки"
                                            Click="NotesButton_OnClick"
                                            Margin="0,0,12,0"/>
                                </StackPanel>
                            </Border>

                            <ToggleButton x:Name="ProfileActionsToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ProfileActionsToggleButtonStyle}"
                                          ToolTip="Показать или скрыть действия профиля"
                                          Margin="0,0,6,8"/>

                            <Button Grid.Column="2"
                                    Content="Запустить"
                                    Command="{Binding LaunchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,0,8"
                                    MinWidth="112"/>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Бинарник"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.ExecutableRelativePath}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Аргументы"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.LaunchArguments}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Модов в профиле"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.Mods.Count}"
                                           FontSize="13"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Наиграно"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.PlaytimeDisplay}"
                                           FontSize="13"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedProfile.LastPlayedDisplay}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="22,0,0,0">
                            <TextBlock Text="Моды"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Моды ниже в списке перезаписывают моды выше"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <ToggleButton Content="Автономный мод"
                                          IsChecked="{Binding SelectedProfile.IsStandalone}"
                                          IsEnabled="{Binding CanEditSelectedProfile}"
                                          Style="{StaticResource ProfileToggleButtonStyle}"
                                          Margin="0,0,8,8"
                                          ToolTipService.InitialShowDelay="600">
                                <ToggleButton.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="260">
                                            Автономный мод имеет свой движок и все файлы игры, запускается из своей папки
                                        </TextBlock>
                                    </ToolTip>
                                </ToggleButton.ToolTip>
                            </ToggleButton>
                            <Button Command="{Binding ScanForModsCommand}"
                                    Style="{StaticResource ModToolbarIconButtonStyle}"
                                    ToolTip="Найти моды в выбранной папке"
                                    Margin="0,0,8,8">
                                <Viewbox Width="26" Height="26">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,5.5 C4,4.672 4.672,4 5.5,4 H10 L12,6 H18.5 C19.328,6 20,6.672 20,7.5 V10"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Path Data="M11.4,19.5 H5.5 C4.672,19.5 4,18.828 4,18 V8"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Ellipse Canvas.Left="12"
                                                 Canvas.Top="11"
                                                 Width="7"
                                                 Height="7"
                                                 Stroke="{StaticResource AccentBrush}"
                                                 StrokeThickness="1.7"/>
                                        <Path Data="M17.5,16.5 L21,20"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding AddModCommand}"
                                    Style="{StaticResource ModToolbarIconButtonStyle}"
                                    ToolTip="Добавить папку мода"
                                    Margin="0,0,8,8">
                                <Viewbox Width="26" Height="26">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V6.5 C4,5.672 4.672,5 5.5,5 H10 L12,7 H18.5 C19.328,7 20,7.672 20,8.5 V18 C20,18.828 19.328,19.5 18.5,19.5 H5.5 C4.672,19.5 4,18.828 4,18 Z"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Path Data="M12,10 V16 M9,13 H15"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                               <ListView x:Name="ModsList"
                                        Margin="0"
                                       SizeChanged="ModsList_SizeChanged"
                                       ItemsSource="{Binding SelectedProfile.Mods}"
                                       SelectedItem="{Binding SelectedMod}"
                                       ItemContainerStyle="{StaticResource ModListViewItemStyle}"
                                       AllowDrop="True"
                                       Drop="ModsList_OnDrop"
                                       DragOver="ModsList_OnDragOver"
                                       DragLeave="ModsList_OnDragLeave"
                                       PreviewMouseLeftButtonDown="ModsList_OnPreviewMouseLeftButtonDown"
                                       PreviewMouseRightButtonDown="ModsList_OnPreviewMouseRightButtonDown"
                                       MouseMove="ModsList_OnMouseMove"
                                        ToolTip="Моды можно перетаскивать между строками; нижние имеют больший приоритет"
                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                        ScrollViewer.CanContentScroll="False"
                                        VirtualizingPanel.ScrollUnit="Pixel"
                                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                                  <ListView.View>
                                     <GridView AllowsColumnReorder="False">
                                         <GridViewColumn Header="#" Width="36" DisplayMemberBinding="{Binding Order}"/>
                                         <GridViewColumn Header="Вкл." Width="50">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                     <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                HorizontalAlignment="Center"
                                                                HorizontalContentAlignment="Center"
                                                                ToolTipService.ShowOnDisabled="True"
                                                                ToolTipService.InitialShowDelay="600">
                                                         <CheckBox.Style>
                                                             <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                 <Setter Property="ToolTip" Value="Прозрачный значок — мод выключен&#x0a;Цветной значок — мод включён"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding DataContext.CanEditSelectedProfile, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                  Value="False">
                                                                         <Setter Property="IsEnabled" Value="False"/>
                                                                         <Setter Property="ToolTip" Value="Нельзя изменять моды, пока профиль запущен"/>
                                                                     </DataTrigger>
                                                                     <MultiDataTrigger>
                                                                         <MultiDataTrigger.Conditions>
                                                                             <Condition Binding="{Binding IsLocked}" Value="True"/>
                                                                             <Condition Binding="{Binding IsEnabled}" Value="True"/>
                                                                         </MultiDataTrigger.Conditions>
                                                                         <MultiDataTrigger.Setters>
                                                                             <Setter Property="IsEnabled" Value="False"/>
                                                                             <Setter Property="ToolTip" Value="Сначала отключите моды ниже в списке"/>
                                                                         </MultiDataTrigger.Setters>
                                                                     </MultiDataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </CheckBox.Style>
                                                     </CheckBox>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                          <GridViewColumn Header="Мод" Width="220" DisplayMemberBinding="{Binding Name}"/>
                                         <GridViewColumn Header="Папка" DisplayMemberBinding="{Binding SourcePath}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Height="3"
                      Margin="0,3,0,3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{StaticResource StrokeBrush}"
                      ResizeDirection="Rows"
                      Visibility="{Binding IsLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,0"
                Visibility="{Binding IsLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Журнал"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
                <TextBox Grid.Row="1"
                         Margin="0,6,0,0"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
