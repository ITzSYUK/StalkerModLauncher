<Window x:Class="StalkerModLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="S.T.A.L.K.E.R. Mod Launcher"
        MinWidth="1280"
        MinHeight="560"
        Width="1280"
        Height="760"
        Background="{StaticResource WindowBackgroundBrush}"
        SourceInitialized="Window_OnSourceInitialized"
        Closing="Window_OnClosing"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="InlineModActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style x:Key="ProfileHeaderIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid Margin="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="OutlineIcon"
                                                  Content="{TemplateBinding Content}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                <ContentPresenter x:Name="FilledIcon"
                                                  Content="{TemplateBinding Tag}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
                                <Setter TargetName="OutlineIcon" Property="Opacity" Value="0"/>
                                <Setter TargetName="FilledIcon" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PanelPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InlineProfileActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
        </Style>
        <Style x:Key="ProfileListBoxItemStyle"
               TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="0">
                            <Grid ClipToBounds="True">
                                <ContentPresenter Margin="12,6"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                <Border x:Name="ActionShade"
                                        Background="#B3000000"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <StackPanel x:Name="ProfileActions"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,5,0"
                                            Opacity="0"
                                            IsHitTestVisible="False">
                                    <StackPanel.RenderTransform>
                                        <TranslateTransform X="18"/>
                                    </StackPanel.RenderTransform>
                                    <Button Style="{StaticResource InlineProfileActionButtonStyle}"
                                            Command="{Binding DataContext.InlineDuplicateProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Создать копию профиля">
                                        <Viewbox Width="16" Height="18">
                                            <Path Fill="{StaticResource TextBrush}"
                                                  Data="M131.07,372.11 C131.44,373.11 131.64,374.19 131.64,375.31 V454.43 C131.64,465.17 136.05,474.96 143.14,482.05 C150.23,489.14 160.01,493.54 170.76,493.54 H409.21 C419.96,493.54 429.74,489.14 436.83,482.05 C443.92,474.96 448.32,465.17 448.32,454.43 V152.42 C448.32,141.87 444.11,132.27 437.3,125.24 L436.83,124.81 C429.74,117.72 419.96,113.31 409.21,113.31 H170.19 C159.44,113.31 149.66,117.72 142.57,124.81 C135.48,131.9 131.07,141.68 131.07,152.42 Z M112.4,384.65 H57.23 C41.41,384.65 27.13,378.07 16.78,367.54 C6.41,356.97 0,342.4 0,326.52 V57.79 C0,41.93 6.5,27.49 16.97,17.01 C27.51,6.49 41.94,0 57.79,0 H301.42 C317.29,0 331.72,6.51 342.19,16.98 C352.7,27.46 359.21,41.94 359.21,57.79 V94.64 H409.21 C425.11,94.64 439.57,101.14 450.03,111.6 C460.5,122.06 467,136.52 467,152.42 V454.43 C467,470.33 460.5,484.79 450.04,495.25 C439.57,505.72 425.11,512.22 409.21,512.22 H170.19 C154.29,512.22 139.84,505.72 129.37,495.25 C118.9,484.79 112.4,470.33 112.4,454.43 Z"/>
                                        </Viewbox>
                                    </Button>
                                    <Button Style="{StaticResource InlineProfileActionButtonStyle}"
                                            Command="{Binding DataContext.InlineDeleteProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Удалить профиль">
                                        <Viewbox Width="16" Height="16">
                                            <Path Fill="{StaticResource DangerBrush}"
                                                  Data="M1.63,97.99 L38.18,61.44 L1.63,24.89 C-0.54,22.72 -0.54,19.16 1.63,16.99 L16.99,1.63 C19.16,-0.54 22.72,-0.54 24.89,1.63 L61.44,38.18 L97.99,1.63 C100.16,-0.54 103.72,-0.54 105.89,1.63 L121.25,16.99 C123.42,19.16 123.42,22.72 121.25,24.89 L84.7,61.44 L121.25,97.99 C123.42,100.16 123.42,103.72 121.25,105.89 L105.89,121.25 C103.72,123.42 100.16,123.42 97.99,121.25 L61.44,84.7 L24.89,121.25 C22.72,123.42 19.16,123.42 16.99,121.25 L1.63,105.89 C-0.54,103.72 -0.54,100.16 1.63,97.99 Z"/>
                                        </Viewbox>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#3A3325"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.45"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="0"
                                                         Duration="0:0:0.38">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.12" Value="True"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.32"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.28"/>
                                        <DoubleAnimation Storyboard.TargetName="ProfileActions"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         To="18"
                                                         Duration="0:0:0.34">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <BooleanAnimationUsingKeyFrames Storyboard.TargetName="ProfileActions"
                                                                        Storyboard.TargetProperty="IsHitTestVisible">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.28" Value="False"/>
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModToolbarIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="450"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ModListViewItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Grid ClipToBounds="True">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <GridViewRowPresenter Grid.Row="0"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                    <TextBlock Grid.Row="1"
                                               Text="Перезаписывает файлы вышестоящих модификаций: могут возникать конфликты."
                                               Foreground="{StaticResource DangerBrush}"
                                               FontSize="9"
                                               Margin="86,0,0,2"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOverlapsAbove}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Border x:Name="ActionShade"
                                        Background="#B3000000"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>

                                <Grid x:Name="ActionRail"
                                      Width="38"
                                      Height="30"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,2,0"
                                      Background="Transparent"
                                      ClipToBounds="True"
                                      Opacity="0"
                                      IsHitTestVisible="False">
                                    <Grid Width="270" HorizontalAlignment="Right">
                                        <StackPanel x:Name="ActionButtons"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,40,0"
                                                    Opacity="0">
                                            <Button Content="Убрать"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineRemoveModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Выше"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineMoveModUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Ниже"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineMoveModDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Открыть"
                                                    Style="{StaticResource InlineModActionButtonStyle}"
                                                    Command="{Binding DataContext.InlineOpenModFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <Border Width="38"
                                                HorizontalAlignment="Right"
                                                Background="Transparent"
                                                Cursor="Hand">
                                            <Grid>
                                                <Image x:Name="LeftChevron"
                                                       Source="/Resources/left-arrow.png"
                                                       Width="22"
                                                       Height="22"/>
                                                <Image x:Name="RightChevron"
                                                       Source="/Resources/right-arrow.png"
                                                       Width="22"
                                                       Height="22"
                                                       Opacity="0"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="{StaticResource PanelAltBrush}"/>
                                <Setter TargetName="ActionRail" Property="Opacity" Value="1"/>
                                <Setter TargetName="ActionRail" Property="IsHitTestVisible" Value="True"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowChrome" Property="Background" Value="#3A3325"/>
                                <Setter TargetName="RowChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <EventTrigger SourceName="ActionRail" RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionRail"
                                                         Storyboard.TargetProperty="Width"
                                                         To="270"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         BeginTime="0:0:0.10"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.65"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="LeftChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.22"/>
                                        <DoubleAnimation Storyboard.TargetName="RightChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.22"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger SourceName="ActionRail" RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActionRail"
                                                         Storyboard.TargetProperty="Width"
                                                         To="38"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="ActionShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="LeftChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.30"/>
                                        <DoubleAnimation Storyboard.TargetName="RightChevron"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.30"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LaunchCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewProfileCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateProfileCommand}"/>
    </Window.InputBindings>
    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{Binding LogRowHeight}"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,0,0,10">
                    <StackPanel Cursor="Hand"
                                MouseDown="Title_MouseDown"
                                HorizontalAlignment="Center">
                        <TextBlock Text="S.T.A.L.K.E.R."
                                   FontSize="25"
                                   FontWeight="Black"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MOD LAUNCHER"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="13"
                                   Margin="0,1,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="12,12,12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Профили"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal">
                                <Button Command="{Binding NewProfileCommand}"
                                        Style="{StaticResource ProfileHeaderIconButtonStyle}"
                                        ToolTip="Создать профиль"
                                        Margin="0,0,3,0">
                                    <Button.Content>
                                        <Viewbox Width="20" Height="20">
                                            <Path Fill="{StaticResource TextBrush}"
                                                  Data="M6.87,0 H49.49 C53.28,0 56.36,3.08 56.36,6.87 V49.3 C56.36,53.09 53.28,56.17 49.49,56.17 H6.87 C3.08,56.17 0,53.09 0,49.3 V6.87 C0,3.08 3.08,0 6.87,0 Z M90.78,66.91 H101.15 C103.28,66.91 105,68.63 105,70.75 V84.81 H119 C121.12,84.81 122.84,86.52 122.84,88.64 V99 C122.84,101.12 121.12,102.83 119,102.83 H105 V116.9 C105,119.02 103.28,120.74 101.17,120.74 H90.78 C88.67,120.74 87,119.02 87,116.9 V102.84 H72.89 C70.77,102.84 69.05,101.12 69.05,99 V88.64 C69.05,86.52 70.77,84.81 72.89,84.81 H87 V70.75 C87,68.63 88.67,66.91 90.78,66.91 Z M6.87,64.87 H49.49 C53.28,64.87 56.36,67.95 56.36,71.74 V114.17 C56.36,117.96 53.28,121.04 49.49,121.04 H6.87 C3.08,121.04 0,117.96 0,114.17 V71.74 C0,67.95 3.08,64.87 6.87,64.87 Z M72.64,0 H115.26 C119.05,0 122.13,3.08 122.13,6.87 V49.3 C122.13,53.09 119.05,56.17 115.26,56.17 H72.64 C68.85,56.17 65.77,53.09 65.77,49.3 V6.87 C65.77,3.08 68.85,0 72.64,0 Z"/>
                                        </Viewbox>
                                    </Button.Content>
                                    <Button.Tag>
                                        <Viewbox Width="20" Height="20">
                                            <Path Fill="{StaticResource AccentBrush}"
                                                  Data="M91.32,69.14 H101.43 C103.5,69.14 105.17,70.81 105.17,72.88 V86.61 H118.89 C120.96,86.61 122.64,88.28 122.64,90.35 V100.46 C122.64,102.53 120.96,104.2 118.89,104.2 H105.17 V117.93 C105.17,120 103.5,121.67 101.43,121.67 H91.32 C89.25,121.67 87.57,120 87.57,117.93 V104.2 H73.85 C71.78,104.2 70.11,102.53 70.11,100.46 V90.35 C70.11,88.28 71.78,86.61 73.85,86.61 H87.57 V72.88 C87.57,70.81 89.25,69.14 91.32,69.14 Z M3.68,69.14 H49.1 C51.13,69.14 52.78,70.79 52.78,72.81 V118 C52.78,120.03 51.13,121.67 49.1,121.67 H3.68 C1.65,121.67 0,120.03 0,118 V72.81 C0,70.79 1.65,69.14 3.68,69.14 Z M73.78,0 H119.21 C121.24,0 122.88,1.64 122.88,3.67 V48.9 C122.88,50.93 121.24,52.58 119.21,52.58 H73.78 C71.75,52.58 70.1,50.93 70.1,48.9 V3.67 C70.1,1.64 71.75,0 73.78,0 Z M3.68,0 H49.1 C51.13,0 52.78,1.64 52.78,3.67 V48.9 C52.78,50.93 51.13,52.58 49.1,52.58 H3.68 C1.65,52.58 0,50.93 0,48.9 V3.67 C0,1.64 1.65,0 3.68,0 Z"/>
                                        </Viewbox>
                                    </Button.Tag>
                                </Button>
                                <Button Command="{Binding ImportProfileCommand}"
                                        Style="{StaticResource ProfileHeaderIconButtonStyle}"
                                        ToolTip="Импортировать профиль">
                                    <Button.Content>
                                        <Viewbox Width="20" Height="20">
                                            <Path Fill="{StaticResource TextBrush}"
                                                  Data="M27.25,0 H95.63 C110.68,0 122.88,12.2 122.88,27.25 V95.63 C122.88,110.68 110.68,122.88 95.63,122.88 H27.25 C12.2,122.88 0,110.68 0,95.63 V27.25 C0,12.2 12.2,0 27.25,0 Z M71.59,50.47 C74.25,47.84 78.5,51.67 76.33,55.3 L63.48,68 C62.16,69.3 60.05,69.3 58.73,68 L46.07,55.48 C43.41,52.85 47.37,48.1 50.81,50.65 L57.81,57.56 L57.88,33.23 C57.88,28.72 64.65,28.72 64.65,33.28 L64.58,57.43 Z M34.48,81.55 L34.53,68.31 C34.53,63.8 41.3,63.8 41.3,68.37 L41.27,78.01 H81.59 L81.62,68.31 C81.62,63.8 88.4,63.8 88.4,68.37 L88.35,81.55 C88.35,83.41 86.84,84.78 85,84.78 H37.89 C36.04,84.78 34.53,83.41 34.48,81.55 Z M95.63,7 H27.25 C16.05,7 7,16.05 7,27.25 V95.63 C7,106.83 16.05,115.92 27.25,115.92 H95.63 C106.83,115.92 115.92,106.83 115.92,95.63 V27.25 C115.92,16.05 106.83,7 95.63,7 Z"/>
                                        </Viewbox>
                                    </Button.Content>
                                    <Button.Tag>
                                        <Viewbox Width="20" Height="20">
                                            <Path Fill="{StaticResource AccentBrush}"
                                                  Data="M25.2,0 H97.68 C111.55,0 122.88,11.33 122.88,25.2 V97.68 C122.88,111.55 111.55,122.88 97.68,122.88 H25.2 C11.33,122.88 0,111.55 0,97.68 V25.2 C0,11.33 11.33,0 25.2,0 Z M72.92,49.32 C76.51,45.78 81.87,51.24 78.29,54.78 L63.75,69.14 C62.27,70.6 59.86,70.6 58.38,69.14 L44.05,55 C40.46,51.46 45.82,46 49.41,49.54 L57.3,57.36 L57.38,29.83 C57.38,24.72 65.04,24.72 65.04,29.89 L65,57.19 Z M31,84.48 L31.05,69.48 C31.05,64.37 38.71,64.37 38.71,69.55 L38.68,80.46 H84.29 L84.32,69.46 C84.32,64.35 91.98,64.35 91.98,69.53 L91.93,84.44 C91.93,86.56 90.2,88.13 88,88.13 H34.72 C32.62,88.13 31.05,86.56 31,84.48 Z"/>
                                        </Viewbox>
                                    </Button.Tag>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="ProfilesList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile}"
                                 ItemContainerStyle="{StaticResource ProfileListBoxItemStyle}"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="ProfilesList_OnPreviewMouseLeftButtonDown"
                                 MouseMove="ProfilesList_OnMouseMove"
                                 DragOver="ProfilesList_OnDragOver"
                                 DragLeave="ProfilesList_OnDragLeave"
                                 Drop="ProfilesList_OnDrop"
                                 ToolTip="Профили можно перетаскивать для изменения порядка"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"/>
                                        <TextBlock Text="Запущен"
                                                   FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,-1,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="2"
                                Content="{Binding LogToggleText}"
                                Command="{Binding ToggleLogCommand}"
                                Margin="12,10,12,12"
                                Padding="6,4"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,8"
                            Margin="0,0,0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile.IsStandalone}" Value="True">
                                        <Setter Property="Opacity" Value="0.35"/>
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Папка игры"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBox Grid.Row="1"
                                         Text="{Binding SelectedProfile.GameInstallPath, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Padding="0,2,0,0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                            <Button Grid.Column="1"
                                    Content="Выбрать игру"
                                    Command="{Binding ChooseGameFolderCommand}"
                                    Margin="12,0,0,0"
                                    MinWidth="120"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="12"
                                    Height="12"
                                    CornerRadius="6"
                                    VerticalAlignment="Top"
                                    Margin="0,8,10,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGameValid}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding SelectedProfile.Name, FallbackValue=Профиль}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ValidationSummary}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"
                                           LineHeight="18"
                                           MaxHeight="54"/>
                            </StackPanel>
                        </Grid>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top"
                                   Margin="16,0,0,0">
                            <Button Content="Состояние"
                                    Click="ProfileHealthButton_OnClick"
                                    Margin="0,0,8,8"/>
                            <Button Content="Настройки"
                                    Click="EditProfileButton_OnClick"
                                    Margin="0,0,8,8"/>
                            <Button Content="Экспорт"
                                    Command="{Binding ExportProfileCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="Профиль"
                                    Command="{Binding OpenProfileFolderCommand}"
                                    Margin="0,0,8,8"/>
                            <Button Content="Скриншоты"
                                    Click="ScreenshotsButton_OnClick"
                                    Margin="0,0,8,8"/>
                            <Button Content="Заметки"
                                    Click="NotesButton_OnClick"
                                    Margin="0,0,8,8"/>
                            <Button Content="Запустить"
                                    Command="{Binding LaunchCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,0,8"
                                    MinWidth="112"/>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Бинарник"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.ExecutableRelativePath}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Аргументы"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.LaunchArguments}"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Модов в профиле"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.Mods.Count}"
                                           FontSize="13"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Наиграно"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{Binding SelectedProfile.PlaytimeDisplay}"
                                           FontSize="13"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding SelectedProfile.LastPlayedDisplay}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="22,0,0,0">
                            <TextBlock Text="Моды"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Ниже мод — выше приоритет"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <ToggleButton Content="Автономный мод"
                                          IsChecked="{Binding SelectedProfile.IsStandalone}"
                                          IsEnabled="{Binding CanEditSelectedProfile}"
                                          Style="{StaticResource ProfileToggleButtonStyle}"
                                          Margin="0,0,8,8"
                                          ToolTipService.InitialShowDelay="600">
                                <ToggleButton.ToolTip>
                                    <ToolTip>
                                        <TextBlock TextWrapping="Wrap" MaxWidth="260">
                                            Автономный мод имеет свой движок и все файлы игры, запускается из своей папки
                                        </TextBlock>
                                    </ToolTip>
                                </ToggleButton.ToolTip>
                            </ToggleButton>
                            <Button Command="{Binding ScanForModsCommand}"
                                    Style="{StaticResource ModToolbarIconButtonStyle}"
                                    ToolTip="Найти моды в выбранной папке"
                                    Margin="0,0,8,8">
                                <Viewbox Width="26" Height="26">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,5.5 C4,4.672 4.672,4 5.5,4 H10 L12,6 H18.5 C19.328,6 20,6.672 20,7.5 V10"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Path Data="M11.4,19.5 H5.5 C4.672,19.5 4,18.828 4,18 V8"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Ellipse Canvas.Left="12"
                                                 Canvas.Top="11"
                                                 Width="7"
                                                 Height="7"
                                                 Stroke="{StaticResource AccentBrush}"
                                                 StrokeThickness="1.7"/>
                                        <Path Data="M17.5,16.5 L21,20"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Command="{Binding AddModCommand}"
                                    Style="{StaticResource ModToolbarIconButtonStyle}"
                                    ToolTip="Добавить папку мода"
                                    Margin="0,0,8,8">
                                <Viewbox Width="26" Height="26">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M4,18 V6.5 C4,5.672 4.672,5 5.5,5 H10 L12,7 H18.5 C19.328,7 20,7.672 20,8.5 V18 C20,18.828 19.328,19.5 18.5,19.5 H5.5 C4.672,19.5 4,18.828 4,18 Z"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="1.7"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                        <Path Data="M12,10 V16 M9,13 H15"
                                              Stroke="{StaticResource AccentBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="{StaticResource FieldBackgroundBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                               <ListView x:Name="ModsList"
                                        Margin="0"
                                       SizeChanged="ModsList_SizeChanged"
                                       ItemsSource="{Binding SelectedProfile.Mods}"
                                       SelectedItem="{Binding SelectedMod}"
                                       ItemContainerStyle="{StaticResource ModListViewItemStyle}"
                                       AllowDrop="True"
                                       Drop="ModsList_OnDrop"
                                       DragOver="ModsList_OnDragOver"
                                       DragLeave="ModsList_OnDragLeave"
                                       PreviewMouseLeftButtonDown="ModsList_OnPreviewMouseLeftButtonDown"
                                       PreviewMouseRightButtonDown="ModsList_OnPreviewMouseRightButtonDown"
                                       MouseMove="ModsList_OnMouseMove"
                                        ToolTip="Моды можно перетаскивать между строками; нижние имеют больший приоритет"
                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                        ScrollViewer.CanContentScroll="False"
                                        VirtualizingPanel.ScrollUnit="Pixel"
                                       ScrollViewer.VerticalScrollBarVisibility="Auto">
                                  <ListView.View>
                                     <GridView AllowsColumnReorder="False">
                                         <GridViewColumn Header="#" Width="36" DisplayMemberBinding="{Binding Order}"/>
                                         <GridViewColumn Header="Вкл." Width="50">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                     <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                HorizontalAlignment="Center"
                                                                HorizontalContentAlignment="Center"
                                                                ToolTipService.ShowOnDisabled="True"
                                                                ToolTipService.InitialShowDelay="600">
                                                         <CheckBox.Style>
                                                             <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                 <Setter Property="ToolTip" Value="Прозрачный значок — мод выключен&#x0a;Цветной значок — мод включён"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding DataContext.CanEditSelectedProfile, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                  Value="False">
                                                                         <Setter Property="IsEnabled" Value="False"/>
                                                                         <Setter Property="ToolTip" Value="Нельзя изменять моды, пока профиль запущен"/>
                                                                     </DataTrigger>
                                                                     <MultiDataTrigger>
                                                                         <MultiDataTrigger.Conditions>
                                                                             <Condition Binding="{Binding IsLocked}" Value="True"/>
                                                                             <Condition Binding="{Binding IsEnabled}" Value="True"/>
                                                                         </MultiDataTrigger.Conditions>
                                                                         <MultiDataTrigger.Setters>
                                                                             <Setter Property="IsEnabled" Value="False"/>
                                                                             <Setter Property="ToolTip" Value="Сначала отключите моды ниже в списке"/>
                                                                         </MultiDataTrigger.Setters>
                                                                     </MultiDataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </CheckBox.Style>
                                                     </CheckBox>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                          <GridViewColumn Header="Мод" Width="220" DisplayMemberBinding="{Binding Name}"/>
                                         <GridViewColumn Header="Папка" DisplayMemberBinding="{Binding SourcePath}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Height="3"
                      Margin="0,3,0,3"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{StaticResource StrokeBrush}"
                      ResizeDirection="Rows"
                      Visibility="{Binding IsLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="10"
                Margin="0,0,0,0"
                Visibility="{Binding IsLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Журнал"
                               FontSize="15"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>
                <TextBox Grid.Row="1"
                         Margin="0,6,0,0"
                         Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
